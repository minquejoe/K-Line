# ========== Backend Configuration ==========

# Server Ports (Change if conflict occurs)
BACKEND_PORT=8000
FRONTEND_PORT=80

# Security (MUST change in production!)
# Generate a strong key: openssl rand -hex 32
SECRET_KEY=your-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ───── Database ─────
# Options: postgresql (production) | sqlite (dev/single-node)
DATABASE_TYPE=postgresql

# PostgreSQL connection (used when DATABASE_TYPE=postgresql)
DATABASE_URL=postgresql://kline_user:kline_pass@localhost:5432/kline_db

# PostgreSQL credentials (for Docker Compose)
POSTGRES_USER=kline_user
POSTGRES_PASSWORD=kline_pass
POSTGRES_DB=kline_db
POSTGRES_PORT=5432

# Connection pool
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ───── Logging ─────
LOG_LEVEL=INFO
DEBUG=false

# Email / SMTP (Optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_password
SMTP_USE_TLS=true

# Data Fetching
DAILY_DATA_FETCH_HOUR=15
DAILY_DATA_FETCH_MINUTE=30
MONITOR_CHECK_INTERVAL=1

# ───── Daily Optimization Task ─────
# Default: runs every day at 15:30 (after market close)
DAILY_TASK_HOUR=15
DAILY_TASK_MINUTE=30
# Recipient email (defaults to SMTP_USER if not set)
NOTIFY_EMAIL=admin@example.com

# ========== Frontend Configuration ==========

# API Configuration
VITE_API_BASE_URL=/

# Deployment Configuration
# Usage: Base path for the application (e.g., /stock/ if deployed under domain.com/stock/)
# Default: /
VITE_BASE_PATH=/