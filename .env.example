# ========== Backend Configuration ==========

# Server Ports (Change if conflict occurs)
BACKEND_PORT=8000
FRONTEND_PORT=80

# Security (Change these in production!)
SECRET_KEY=your-secret-key-change-this-in-production-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database (Default uses SQLite in data/database/kline.db)
# DATABASE_URL=sqlite:///./data/database/kline.db

# Email / SMTP (Optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_password
SMTP_USE_TLS=true

# Data Fetching
DAILY_DATA_FETCH_HOUR=15
DAILY_DATA_FETCH_MINUTE=30
MONITOR_CHECK_INTERVAL=1

# ========== Frontend Configuration ==========

# API Configuration
VITE_API_BASE_URL=/

# Deployment Configuration
# Usage: Base path for the application (e.g., /stock/ if deployed under domain.com/stock/)
# Default: /
VITE_BASE_PATH=/